<% layout("/layouts/boilerplate") -%>

<body>
  <!--  <h3>All Listings</h3>
    <form method="GET" action="/listings/new">
     <button> Create New Listing </button>  
    </form>-->

    <style>

          #filter {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
          }
          .filter{
            text-align: center;
            margin-right: 2rem;
            margin-top: 2rem;
            text-decoration: none;
            color: black;
            display: flex;
            flex-direction: column;
            opacity: 0.6;
          }
          .filter:hover{
            opacity: 1;
            cursor: pointer;
          }
          .filter p{
            font-size: 0.9rem;
          }
          .tax-info{
           display: none;
          }
          .tax-toggle{
            border: 1px solid black;
            border-radius: 1rem;
            height: 3rem;
            padding: 1rem;
            margin-left: 2rem;
            display: flex;
            align-items: center;
          }
          .taxx-toggle{
            display: none;
          }
      
  @media (max-width:768px){
     .taxx-toggle{
            width: fit-content;
            border: 1px solid black;
            border-radius: 1rem;
            height: 2rem;
            padding: 1rem;
            margin-top: 1rem;
            margin-left: auto !important;
            margin-right: 1rem;
            font-size: 1rem;
            display: flex;
            align-items: center !important;
          }
          .tax-toggle{
            display: none;
          }
  }
    </style>

  <div id="filter" class="d-flex flex-nowrap overflow-auto">
      <a href="/listings?category=Trending" class="filter">
        <div><i class="fa-solid fa-fire"></i></div>
          <p>Trending</p>
      </a>
      <a href="/listings?category=Trending" class="filter">
        <div><i class="fa-solid fa-bed"></i></i></div>
        <p>Rooms</p>
      </a>
      <a href="/listings?category=Trending" class="filter">
        <div><i class="fa-solid fa-mountain-city"></i></i></div>
        <p>Iconic Cities</p>
      </a>
      <a href="/listings?category=Trending" class="filter">
        <div><i class="fa-solid fa-building-columns"></i></i></div>
        <p>Resorts</p>
      </a>
      <a href="/listings?category=Trending" class="filter">
        <div><i class="fa-solid fa-mountain"></i></i></i></div>
        <p>Mountains</p>
      </a>
      <a href="/listings?category=Trending" class="filter">
        <div><i class="fa-brands fa-fort-awesome"></i></i></div>
        <p>Castles</p>
      </a>
      <a href="/listings?category=Trending" class="filter">
        <div><i class="fa-solid fa-person-swimming"></i></i></i></div>
        <p>Beachfront</p>
      </a>
      <a href="/listings?category=Trending" class="filter">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Campgrounds</p>
      </a>
      <a href="/listings?category=Trending" class="filter">
        <div><i class="fa-solid fa-snowflake"></i></i></div>
        <p>Arctic</p>
      </a>
      <a href="/listings?category=Trending" class="filter">
        <div><i class="fa-solid fa-tree-city"></i></div>
        <p>City Escape</p>
      </a>
      <a href="/listings?category=Trending" class="filter">
        <div><i class="fa-solid fa-landmark-dome"></i></div>
        <p>Domes</p>
      </a>

      <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
          <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
          <label class="form-check-label" for="switchCheckDefault">
            Display total after taxes
          </label>
        </div>
      </div>
  </div>

  <div class="taxx-toggle">
        <div class="form-check-reverse form-switch">
          <input class="form-check-input" type="checkbox" role="switch" id="taxSwitchMobile">
          <label class="form-check-label" for="taxSwitchMobile">
            Total Taxes
          </label>
        </div>
  </div>

    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <% for(let listing of allListings) { %>
        <a href="/listings/<%=listing._id%>" class="listing-link">
          <div class="card col listing-card">
            <img src="<%= listing.image.url %>" 
              class="card-img-top" 
              alt="listing-image" 
              style="height:20rem" 
            />
            <%# I am using Image overlay property in Bootstrap and then 
                Give style in this card-img-overlay calss %>
            <div class="card-img-overlay">
            </div>

            <div class="card-body">
              <p class="card-text">
                <b><%=listing.title%></b> <br/>
              &#8377; <%= listing.price?.toLocaleString("en-IN") || "0" %> /night
              <i class="tax-info">&nbsp;&nbsp;+18% GST</i>
              </p>
            </div>
          </div>
        </a>
    <% } %>
  </div>

<% if(false) { %>
  <ul>
    <% for (let listing of allListings ) { %>
      <li>
        <a href="/listings/<%= listing._id %>">
          <%= listing.title %>
        </a>
      </li>
    <% } %> 
  </ul>
<% } %>
</body>
<script>
  let taxSwitchDesktop = document.getElementById("switchCheckDefault");
  let taxSwitchMobile = document.getElementById("taxSwitchMobile");

  taxSwitchDesktop.addEventListener("change", applyTax);
  taxSwitchMobile.addEventListener("change", applyTax);

  function applyTax() {
    let taxInfo = document.getElementsByClassName("tax-info");
    let isChecked = this.checked;
    for(info of taxInfo){
      if(isChecked){
        info.style.display = "inline";
      } else {
        info.style.display = "none";
      }
    }
  };
  </script>
